# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace API Configuration (Primary)
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# OpenRouter API Configuration (Fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# HuggingFace Models (used when HUGGINGFACEHUB_API_TOKEN is set)
HF_HEAVY_MODEL=Qwen/Qwen2.5-72B-Instruct
HF_FLASH_MODEL=Qwen/Qwen2.5-32B-Instruct

# OpenRouter Models (used when OPENROUTER_API_KEY is set)
OR_HEAVY_MODEL=google/gemini-2.0-pro-exp-02-05:free
OR_FLASH_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
OR_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Database Configuration
DATABASE_PATH=data/content_history.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# LangChain Configuration
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=YTA-System

# Vector DB Configuration (Optional)
CHROMA_DB_PATH=data/chroma_db
ENABLE_VECTOR_DB=false

# Channel Defaults Profile (Optional)
CHANNEL_PROFILE_PATH=data/channel_profile.json
