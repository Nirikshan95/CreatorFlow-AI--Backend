# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace API Configuration (Primary)
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# OpenRouter API Configuration (Fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Configuration
PRIMARY_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
FALLBACK_MODEL=mistralai/mistral-7b-instruct:free

# Database Configuration
DATABASE_PATH=data/content_history.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# LangChain Configuration
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=YTA-System

# Vector DB Configuration (Optional)
CHROMA_DB_PATH=data/chroma_db
ENABLE_VECTOR_DB=false
